# Fase 2 — tekst-AI (Claude). Kopieer dit bestand naar .env.local en vul je eigen key in.
ANTHROPIC_API_KEY=
# Standaard Sonnet 5: foutloos Nederlands en sterke verhalen. Voor goedkoper/sneller
# testen kun je claude-haiku-4-5 gebruiken (wel meer taalfoutjes).
ANTHROPIC_MODEL=claude-sonnet-5

# Fase 4 — beeld-AI (fal.ai)
FAL_KEY=
# Harde daglimiet aan illustraties per kind (kostenrem). Default in code = 15 als deze
# ontbreekt. Lager zetten = zuiniger.
MAX_IMAGES_PER_DAY_PER_CHILD=15

# Beeldmodel omschakelbaar (kosten/snelheid). Default = fal-ai/nano-banana-2 (mooiste, echte
# scène-composer). Voor goedkoper/sneller testen kun je bv. IMAGE_MODEL=fal-ai/flux/schnell
# gebruiken. IMAGE_EDIT_MODEL is het beeld-naar-beeld (referentie) model; laat het leeg
# (IMAGE_EDIT_MODEL=) om referentie-consistentie uit te zetten en terug te vallen op
# tekst-naar-plaatje. Zonder deze twee vars blijft alles op nano-banana-2 staan.
# IMAGE_MODEL=fal-ai/nano-banana-2
# IMAGE_EDIT_MODEL=fal-ai/nano-banana-2/edit

# Supabase (live gaan). Project URL + service_role key uit Dashboard → Project Settings → API.
# Server-only; RLS staat aan. Niet committen — .env.local staat in .gitignore.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
