# Fase 2 — tekst-AI (Claude). Kopieer dit bestand naar .env.local en vul je eigen key in.
ANTHROPIC_API_KEY=
# Standaard Sonnet 5: foutloos Nederlands en sterke verhalen. Voor goedkoper/sneller
# testen kun je claude-haiku-4-5 gebruiken (wel meer taalfoutjes).
ANTHROPIC_MODEL=claude-sonnet-5

# Fase 4 — beeld-AI (fal.ai)
FAL_KEY=
# Harde daglimiet aan illustraties per kind (kostenrem). Default in code = 15 als deze
# ontbreekt. Op de lite-modellen (zie hieronder, ~$0,03/plaatje) kan dit ruim omhoog zonder
# duur te worden — 40 is ruim genoeg voor een paar boeken per dag.
MAX_IMAGES_PER_DAY_PER_CHILD=40

# Beeldmodel omschakelbaar (kosten/snelheid). Code-default = fal-ai/nano-banana-2 (mooiste,
# echte scène-composer, ~$0,07/plaatje). Aanrader voor dagelijks gebruik: de "lite"-familie,
# ~2x goedkoper en veel sneller bij bijna gelijke kwaliteit — LET OP: die zit bij fal.ai onder
# de "google/"-namespace, niet "fal-ai/" (fal-ai/nano-banana-lite bestaat niet en faalt altijd
# stil). IMAGE_EDIT_MODEL is het beeld-naar-beeld (referentie) model; laat het leeg
# (IMAGE_EDIT_MODEL=) om referentie-consistentie uit te zetten en terug te vallen op
# tekst-naar-plaatje. Zonder deze twee vars blijft alles op nano-banana-2 staan.
IMAGE_MODEL=google/nano-banana-2-lite
IMAGE_EDIT_MODEL=google/nano-banana-2-lite/edit

# Supabase (live gaan). Project URL + service_role key uit Dashboard → Project Settings → API.
# Server-only; RLS staat aan. Niet committen — .env.local staat in .gitignore.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
